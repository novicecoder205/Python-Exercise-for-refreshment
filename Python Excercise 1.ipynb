   "source": [
    "Ex 1: Practice Problem: Write a Python function that accepts two integer numbers. If the product of the two numbers is less than or equal to 1000, return their product; otherwise, return their sum.\n",
    "\n",
    "Exercise Purpose: Learn basic control flow and the use of if-else statements. Understand how code decisions change output based on a mathematical threshold.\n",
    "\n",
    "Given Input:\n",
    "\n",
    "Case 1: number1 = 20, number2 = 30\n",
    "Case 2: number1 = 40, number2 = 30"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "589df5fd-09c4-4e42-834b-d2bbc0ae5ee7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "please input the first value:  40\n",
      "please input the second value:  30\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "70\n"
     ]
    }
   ],
   "source": [
    "first = int(input(\"please input the first value: \" ))\n",
    "second = int(input(\"please input the second value: \"))\n",
    "sum = first + second\n",
    "product = first * second\n",
    "if (first * second) <= 1000:\n",
    "    print (product)\n",
    "else:\n",
    "    print(sum)\n"
   ]
  },
